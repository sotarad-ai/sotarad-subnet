# SotaRad Subnet Validator Configuration
# Copy this file to .env and update the values.

# ── Chain ────────────────────────────────────────────────────────────────────
NETWORK=finney          # finney (mainnet) | test (testnet) | local
NETUID=1                # Your subnet's netuid

# ── Wallet ───────────────────────────────────────────────────────────────────
WALLET_NAME=default     # Coldkey wallet name
HOTKEY_NAME=default     # Hotkey name

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ── Persistence ──────────────────────────────────────────────────────────────
DB_PATH=validator_scores.db   # SQLite file path for daily evaluation scores

# ── Public evaluation dataset API ────────────────────────────────────────────
# The validator fetches labelled chest X-ray studies from this endpoint.
#
# Expected contract:
#   GET {DATASET_BASE_URL}/studies
#       ?after=<YYYY-MM-DD>&before=<YYYY-MM-DD>&limit=<int>
#   → {
#       "studies": [{
#         "study_id": str,
#         "image_file": str,           # filename OR full URL
#         "acquisition_date": str,     # "YYYY-MM-DD"
#         "report_findings": {
#           "positive_findings": [{"condition": str, "status": str, ...}]
#         }
#       }]
#     }
#
# See data/results.json for a concrete example of this schema.
#
DATASET_BASE_URL=       # e.g. https://data.sotarad.ai
DATASET_API_KEY=        # Bearer token if the dataset API requires auth

# Base URL prepended to image_file values that are bare filenames (not full URLs).
# E.g. if image_file="1.png" and IMAGE_BASE_URL="https://data.sotarad.ai/images",
# the validator will fetch https://data.sotarad.ai/images/1.png
IMAGE_BASE_URL=         # e.g. https://data.sotarad.ai/images

# ── Label / scoring configuration ─────────────────────────────────────────────
# Ground-truth screen-positive conditions (dataset API positive_findings[].condition
# when status == "active") are hardcoded in validator.py as EVAL_TARGET_CONDITIONS.
# Keep aligned with prompts/system_prompt.TARGET_CONDITIONS for miner prompts.

# ── Evaluation parameters ────────────────────────────────────────────────────
EVAL_SAMPLES_PER_DAY=100   # Max samples fetched per evaluation pass
EVAL_PERIOD_MINUTES=1440   # Eval period length (default 24h). period_id = floor(unix_ts / (60*minutes))
EVAL_DELAY_MINUTES=1440    # Min minutes after on-chain commit before miner is evaluated (default ≈ 1 day)

# ── Scoring ──────────────────────────────────────────────────────────────────
FBETA_BETA=2.0   # β for Fβ score.  β>1 weights recall more heavily than precision.
                 # Default β=2 (F2) suits pre-screening: penalises missed positives.

# ── Chutes / model inference ─────────────────────────────────────────────────
# Miners deploy vision-language models to Chutes and commit the chute_id on-chain.
# The validator routes inference requests to the Chutes OpenAI-compatible API.
#
CHUTES_API_KEY=          # cpk_... (get from chutes.ai)
CHUTES_LLM_URL=https://llm.chutes.ai/v1   # Base URL for OpenAI-compatible endpoint
CHUTES_TIMEOUT=60        # Per-request inference timeout (seconds)
CHUTES_MAX_TOKENS=1024   # Room for JSON array of findings (see prompts/system_prompt.py)
CHUTES_MAX_CONCURRENT=4  # Max parallel miner evaluations
# Optional: pass system prompt as role=system (some APIs reject vision+system; default is merge into user)
# CHUTES_SEPARATE_SYSTEM=1   # use CLI --chutes-separate-system instead when running validator.py

# ── Operational ──────────────────────────────────────────────────────────────
HEARTBEAT_TIMEOUT=600   # Seconds without a loop heartbeat before auto-restart
